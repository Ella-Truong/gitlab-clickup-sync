{
    "compilerOptions": {
      //default root folder for all projects
      "rootDir": ".",
      "target": "ES2020",
      "module": "CommonJS",
  
      "strict": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
  
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
  
      "types": ["node"]
    }
  }